{
  "name": "@asciidoctor/reveal.js",
  "version": "5.3.0-dev",
  "description": "A reveal.js converter for Asciidoctor.js. Write your slides in AsciiDoc!",
  "type": "module",
  "main": "js/src/index.js",
  "exports": "./js/src/index.js",
  "engines": {
    "node": ">=20",
    "npm": ">=8.0.0"
  },
  "bin": {
    "asciidoctor-revealjs": "js/bin/asciidoctor-revealjs"
  },
  "files": [
    "js/bin",
    "js/src",
    "data"
  ],
  "scripts": {
    "test": "node --test js/test/**.test.js",
    "examples": "node tasks/examples.js",
    "release:description": "node tasks/release/description.js",
    "release:prepare": "node tasks/release/prepare.js",
    "release:next": "node tasks/release/next.js",
    "build:sea": "node tasks/sea/build.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asciidoctor/asciidoctor-reveal.js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "asciidoc",
    "asciidoctor",
    "javascript",
    "library",
    "backend",
    "template",
    "reveal.js"
  ],
  "authors": [
    "Olivier Bilodeau (https://github.com/obilodeau)",
    "Guillaume Grossetie (https://github.com/ggrossetie)"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/asciidoctor/asciidoctor-reveal.js/issues"
  },
  "homepage": "https://github.com/asciidoctor/asciidoctor-reveal.js",
  "dependencies": {
    "reveal.js": "6.0.1"
  },
  "peerDependencies": {
    "asciidoctor": ">=4.0.0-alpha.6 <5.0.0"
  },
  "devDependencies": {
    "asciidoctor": "^4.0.0-alpha.6",
    "esbuild": "^0.28.0",
    "postject": "^1.0.0-alpha.6"
  },
  "volta": {
    "node": "24.16.0"
  }
}
